{
  "manifest_version": 3,
  "name": "FRC Tooltip",
  "version": "1.0",
  "description": "Shows FRC team names when hovering over team numbers.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "action": {
    "default_title": "FRC Tooltip"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "teams.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
